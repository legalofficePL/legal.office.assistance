<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Formularz klienta – Prison Justice PL</title>
<meta name="description" content="Formularz klienta Prison Justice PL. Wypełnij dane osobowe, informacje o sprawie i więzieniach. Po wysłaniu otrzymasz JSON i PDF z danymi do dalszego przetwarzania.">

<!-- CDN do jsPDF -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>

<style>
body { font-family: Arial, sans-serif; background:#f4f4f4; margin:0; padding:0; }
.container { max-width:800px; margin:20px auto; background:#fff; padding:20px; border-radius:6px; }
.step { display:none; }
.step.active { display:block; }
label { display:block; margin-top:12px; font-weight:bold; }
input, textarea, select { width:100%; padding:8px; margin-top:4px; }
textarea { min-height:80px; }
button { padding:10px 16px; cursor:pointer; margin-top:15px; }
.box { border:1px solid #ccc; padding:12px; margin-top:15px; border-radius:4px; }
.progress { height:8px; background:#ddd; border-radius:4px; margin-bottom:20px; }
.progress-bar { height:8px; background:#4caf50; width:0%; border-radius:4px; }
.preview { white-space:pre-wrap; background:#f9f9f9; padding:12px; }
.info { font-size: 0.9em; color: #555; margin-top:5px; }
</style>
</head>

<body>
<div class="container">

<div class="progress">
  <div class="progress-bar" id="progressBar"></div>
</div>

<form id="form">

<!-- STEP 1: Dane osobowe -->
<div class="step active">
  <h2>Dane osobowe</h2>
  <label>Imię</label>
  <input type="text" id="firstName">
  <label>Nazwisko</label>
  <input type="text" id="lastName">
  <label>Adres (ulica, numer domu, nr mieszkania, kod pocztowy, miasto, kraj)</label>
  <textarea id="address"></textarea>
</div>

<!-- STEP 2: Kontakt -->
<div class="step">
  <h2>Kontakt</h2>
  <label>Telefon</label>
  <input type="text" id="phone">
  <label>Email</label>
  <input type="email" id="email">
</div>

<!-- STEP 3: Dane sprawy -->
<div class="step">
  <h2>Dane sprawy</h2>
  <label>Sygnatura wyroku (wyroku na podstawie którego dostałeś karę w Słowenii)</label>
  <input type="text" id="caseNo">
  <label>Data wyroku</label>
  <input type="date" id="judgmentDate">
  <label>Miasto sądu skazującego (np.: Kreśko, Ljubljana etc.)</label>
  <input type="text" id="courtCity">
</div>

<!-- STEP 4: Język i regulaminy -->
<div class="step">
  <h2>Język i regulaminy</h2>
  <label>Język w którym rozumiesz przepisy</label>
  <input type="text" id="languageUnderstood">
  <label>Czy otrzymałeś regulamin?</label>
  <select id="regulations">
    <option value="TAK">TAK</option>
    <option value="NIE">NIE</option>
  </select>
</div>

<!-- STEP 5: Więzienia i cele -->
<div class="step">
  <h2>Więzienie i cela</h2>
  <p>Opisz każde więzienie i celę, w której przebywałeś.</p>
  <div id="prisons"></div>
  <button type="button" onclick="addPrison()">➕ Dodaj więzienie</button>
</div>

<!-- STEP 6: Podgląd -->
<div class="step">
  <h2>Podgląd</h2>
  <div class="info">To są dane klienta w formie niezbędnej do wypełnienia dokumentu przez Prison Justice PL.</div>
  <div class="preview" id="preview"></div>
  <button type="button" onclick="downloadTXT()">Zapisz na swoim urządzeniu (TXT)</button>
  <button type="button" onclick="downloadPDF()">Zapisz na swoim urządzeniu (PDF)</button>
  <button type="button" onclick="sendByEmail()">Wyślij mailem</button>
</div>

<!-- Nawigacja -->
<div style="margin-top:20px">
  <button type="button" onclick="prev()">Powrót</button>
  <button type="button" onclick="next()">Dalej</button>
</div>

</form>
</div>

<script>
let step = 0;
const steps = document.querySelectorAll(".step");
const progressBar = document.getElementById("progressBar");

function showStep(){
  steps.forEach((s,i)=>s.classList.toggle("active", i===step));
  progressBar.style.width = ((step+1)/steps.length*100)+"%";
  if(step===steps.length-1) buildPreview();
}

function next(){ if(step<steps.length-1){ step++; showStep(); } }
function prev(){ if(step>0){ step--; showStep(); } }

function addPrison(){
  const d=document.createElement("div");
  d.className="box";
  d.innerHTML=`
    <label>Więzienie</label>
    <input type="text">
    <div class="cells"></div>
    <button type="button" onclick="addCell(this)">➕ Dodaj celę</button>
  `;
  document.getElementById("prisons").appendChild(d);
}

function addCell(btn){
  const c=document.createElement("div");
  c.className="box";
  c.innerHTML=`<label>Opis celi</label><textarea></textarea>`;
  btn.parentElement.querySelector(".cells").appendChild(c);
}

function collectFormData() {
  const prisonsArr = [];
  document.querySelectorAll("#prisons .box").forEach(pr => {
    const prisonName = pr.querySelector("input").value;
    const cells = [];
    pr.querySelectorAll("textarea").forEach(t => cells.push(t.value));
    prisonsArr.push({name: prisonName, cells: cells});
  });

  return {
    first_name: document.getElementById("firstName").value,
    last_name: document.getElementById("lastName").value,
    address: document.getElementById("address").value,
    phone: document.getElementById("phone").value,
    email: document.getElementById("email").value,
    case: {
      signature: document.getElementById("caseNo").value,
      judgment_date: document.getElementById("judgmentDate").value,
      court_city: document.getElementById("courtCity").value
    },
    language_understood: document.getElementById("languageUnderstood").value,
    regulations_received: document.getElementById("regulations").value,
    prisons: prisonsArr
  };
}

function buildPreview(){
  const data = collectFormData();
  document.getElementById("preview").textContent = JSON.stringify(data, null, 2);
}

function downloadTXT(){
  const blob=new Blob([document.getElementById("preview").textContent],{type:"text/plain"});
  const a=document.createElement("a");
  a.href=URL.createObjectURL(blob);
  a.download="formularz.txt";
  a.click();
}

function downloadPDF(){
  const { jsPDF } = window.jspdf;
  const doc = new jsPDF();
  const content = document.getElementById("preview").textContent;
  const lines = doc.splitTextToSize(content, 180);
  doc.text(lines, 10, 10);
  doc.save("formularz.pdf");
}

function sendByEmail(){
  const data = collectFormData();
  const json = JSON.stringify(data, null, 2);
  const subject = encodeURIComponent("Prison Justice – formularz klienta");
  const body = encodeURIComponent("Proszę nie zmieniać formatu danych.\n\n" + json);
  window.location.href = `mailto:twojemail@domena.pl?subject=${subject}&body=${body}`;
}

showStep();
</script>
</body>
</html>
